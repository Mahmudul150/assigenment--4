model User {
  id           String     @id @default(uuid())
  name         String     @db.VarChar(255)
  email        String     @unique
  password     String
  phone        String?
  address      String?
  profileImage String?
  role         Role       @default(CUSTOMER)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  providedGears GearItem[]
  rentals       RentalOrder[]
  reviews       Review[]

  @@map("users")
}
